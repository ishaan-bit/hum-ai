{
  "//": "Browser tsconfig for the Hum AI web client. Isolated from the repo-root typecheck so packages stay DOM-free; this one adds the DOM lib + vite/client (import.meta.env).",
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "noEmit": true,
    "baseUrl": "../..",
    "paths": {
      "@hum-ai/shared-types": ["packages/shared-types/src/index.ts"],
      "@hum-ai/audio-features": ["packages/audio-features/src/index.ts"],
      "@hum-ai/affect-model-contracts": ["packages/affect-model-contracts/src/index.ts"],
      "@hum-ai/quality-gate": ["packages/quality-gate/src/index.ts"],
      "@hum-ai/domain-classifier": ["packages/domain-classifier/src/index.ts"],
      "@hum-ai/expert-ser": ["packages/expert-ser/src/index.ts"],
      "@hum-ai/fusion-engine": ["packages/fusion-engine/src/index.ts"],
      "@hum-ai/personalization-engine": ["packages/personalization-engine/src/index.ts"],
      "@hum-ai/relapse-engine": ["packages/relapse-engine/src/index.ts"],
      "@hum-ai/intervention-engine": ["packages/intervention-engine/src/index.ts"],
      "@hum-ai/safety-language": ["packages/safety-language/src/index.ts"],
      "@hum-ai/orchestrator": ["packages/orchestrator/src/index.ts"],
      "@hum-ai/signal-lab/model": ["packages/signal-lab/src/model.ts"],
      "@hum-ai/signal-lab/expert": ["packages/signal-lab/src/expert.ts"],
      "@hum-ai/signal-lab/axis-prior": ["packages/signal-lab/src/axis-prior.ts"],
      "@hum-ai/signal-lab/capture-gate": ["packages/signal-lab/src/capture-gate.ts"]
    }
  },
  "include": ["src/app/**/*.ts", "src/vite-env.d.ts"],
  "exclude": []
}
