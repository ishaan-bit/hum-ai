# =============================================================================
# Hum AI — environment variable template
# Copy to `.env` (git-ignored) and fill in real values locally. NEVER commit a
# populated `.env`. All Hum AI variables use the HUM_AI_ prefix.
#
# Nothing here is required to run `npm test` / `npm run typecheck` — the
# foundation packages are pure TypeScript with no runtime config. These are the
# slots the app/ops surfaces will use as they come online.
# =============================================================================

# --- Core ---
# Deployment environment: development | preview | production
HUM_AI_ENV=development

# --- Privacy posture (local-first defaults) ---
# Raw audio NEVER leaves the device by default. Only flip these with real,
# scoped user consent wired through the consent UI (see ADR-0006, DATA_GOVERNANCE).
HUM_AI_ALLOW_DERIVED_FEATURE_SYNC=false
HUM_AI_ALLOW_RESEARCH_AUDIO_UPLOAD=false
HUM_AI_ALLOW_CLINICAL_RISK_SURFACING=false

# --- Firebase (derived-feature sync target; optional, off by default) ---
# Public client config only. The service-account JSON is a SECRET — never put it
# here or anywhere in the repo (it is git-ignored).
HUM_AI_FIREBASE_API_KEY=
HUM_AI_FIREBASE_PROJECT_ID=
HUM_AI_FIREBASE_APP_ID=
# Path to a LOCAL service-account file outside the repo, e.g. ~/.secrets/hum-ai-sa.json
HUM_AI_FIREBASE_SERVICE_ACCOUNT_PATH=

# --- Model / inference (future; experts are heuristic stubs this pass) ---
HUM_AI_MODEL_VERSION=foundation-0.0.0
# Path to LOCAL model weights outside the repo (weights are never committed).
HUM_AI_MODEL_WEIGHTS_PATH=

# --- Vercel (set in the Vercel dashboard, NOT committed) ---
# Listed for documentation; configure these as Vercel project env vars.
# HUM_AI_PUBLIC_BASE_URL=
