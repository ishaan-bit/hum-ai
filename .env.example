# =============================================================================
# Hum AI — environment variable template
# Copy to `.env` (git-ignored) and fill in real values locally. NEVER commit a
# populated `.env`. All Hum AI variables use the HUM_AI_ prefix.
#
# Nothing here is required to run `npm test` / `npm run typecheck` — the
# foundation packages are pure TypeScript with no runtime config. These are the
# slots the app/ops surfaces will use as they come online.
# =============================================================================

# --- Core ---
# Deployment environment: development | preview | production
HUM_AI_ENV=development

# --- Privacy posture (local-first defaults) ---
# Raw audio NEVER leaves the device by default. Only flip these with real,
# scoped user consent wired through the consent UI (see ADR-0006, DATA_GOVERNANCE).
HUM_AI_ALLOW_DERIVED_FEATURE_SYNC=false
HUM_AI_ALLOW_RESEARCH_AUDIO_UPLOAD=false
HUM_AI_ALLOW_CLINICAL_RISK_SURFACING=false

# --- Firebase (derived-feature sync target; optional, off by default) ---
# Public client config only — copy these from Firebase Console → Project settings
# → Your apps → SDK setup. The service-account JSON is a SECRET; never put it
# here or anywhere in the repo (it is git-ignored).
# Project: humai-core-prod (display name: HumAI)
# These values are public web-client identifiers (safe to commit per Firebase docs).
HUM_AI_FIREBASE_API_KEY=AIzaSyB_iX4JZ7dWq-ZZ3V0fC3afW794CrfY-zE
HUM_AI_FIREBASE_AUTH_DOMAIN=humai-core-prod.firebaseapp.com
HUM_AI_FIREBASE_PROJECT_ID=humai-core-prod
HUM_AI_FIREBASE_STORAGE_BUCKET=humai-core-prod.firebasestorage.app
HUM_AI_FIREBASE_MESSAGING_SENDER_ID=619585998507
HUM_AI_FIREBASE_APP_ID=1:619585998507:web:16802caa2846bce32671ee
# Path to a LOCAL service-account file outside the repo, e.g. ~/.secrets/hum-ai-sa.json
HUM_AI_FIREBASE_SERVICE_ACCOUNT_PATH=

# --- Model / inference (future; experts are heuristic stubs this pass) ---
HUM_AI_MODEL_VERSION=foundation-0.0.0
# Path to LOCAL model weights outside the repo (weights are never committed).
HUM_AI_MODEL_WEIGHTS_PATH=

# --- Sound Lab (optional) ---
# Public, referrer-restricted YouTube Data API v3 key for the Sound Lab's in-app
# player (it resolves the read+taste search to an embeddable track). Safe to embed
# in the static bundle when restricted by HTTP referrer in the Google Cloud console.
# Leave unset to ship the Sound Lab WITHOUT in-app playback: it then degrades to an
# "Open on YouTube" search link (the rest of the tab still works).
HUM_AI_YOUTUBE_API_KEY=

# --- Vercel (set in the Vercel dashboard, NOT committed) ---
# Listed for documentation; configure these as Vercel project env vars.
# HUM_AI_PUBLIC_BASE_URL=

# --- Research datasets (LOCAL ONLY — never committed) ---
# Local folder holding public voice datasets (RAVDESS, CREMA-D, TESS, SAVEE,
# EmoDB) for the dataset harness. Lives OUTSIDE the repo. If unset, the harness
# defaults to ../hum-ai-data (a sibling of the repo root). Manifests are written
# under <HUM_DATA_DIR>/.manifests/ which is git-ignored. See
# docs/research-datasets.md. Placeholder only — no real path committed.
# Recommended: ../hum-ai-data
HUM_DATA_DIR=
