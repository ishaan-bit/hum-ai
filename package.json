{
  "name": "hum-ai",
  "version": "0.0.0",
  "private": true,
  "description": "Hum AI — a domain-aware, personalized, multimodal voice biomarker and affective modeling platform built around a standardized 12-second hum.",
  "type": "module",
  "engines": {
    "node": ">=22.6"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "test": "node --import tsx --test \"packages/**/test/**/*.test.ts\" \"apps/**/test/**/*.test.ts\"",
    "test:watch": "node --import tsx --test --watch \"packages/**/test/**/*.test.ts\" \"apps/**/test/**/*.test.ts\"",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:web": "tsc --noEmit -p apps/web/tsconfig.json",
    "check": "npm run typecheck && npm run typecheck:web && npm test",
    "build:web": "npm run build --workspace @hum-ai/app-web",
    "dev:web": "npm run dev --workspace @hum-ai/app-web",
    "qa": "node --import tsx packages/qa-gates/src/cli.ts",
    "qa:all": "npm run check && npm run qa",
    "data:manifest": "node --import tsx packages/dataset-harness/src/cli.ts manifest",
    "data:validate": "node --import tsx packages/dataset-harness/src/cli.ts validate",
    "demo:voice": "node --import tsx apps/web/demo/voice-core-demo.ts",
    "demo:spine": "node --import tsx apps/web/demo/full-spine-demo.ts",
    "demo:cycle": "node --import tsx apps/web/demo/cycle-demo.ts",
    "signal:availability": "node --import tsx packages/signal-lab/src/cli.ts availability",
    "signal:extract": "node --import tsx packages/signal-lab/src/cli.ts extract",
    "signal:train": "node --import tsx packages/signal-lab/src/cli.ts train",
    "signal:infer": "node --import tsx packages/signal-lab/src/cli.ts infer",
    "signal:experiment": "node --import tsx packages/signal-lab/src/cli.ts experiment",
    "signal:axes": "node --import tsx packages/signal-lab/src/cli.ts axes",
    "signal:export-neural": "node --import tsx packages/signal-lab/src/cli.ts export-neural",
    "signal:all": "node --import tsx packages/signal-lab/src/cli.ts all",
    "firebase:smoke": "node --import tsx apps/web/demo/firebase-smoke.ts"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
